NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/copilot_db
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=sk-ant-your-key-here
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
ALLOWED_ORIGIN=http://localhost:4200

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-at-least-32-chars-long-replace-with-random
JWT_REFRESH_SECRET=change-me-at-least-32-chars-long-different-secret

# MCP HTTP transport ports (optional — these are the defaults)
MCP_POSTGRES_HTTP_PORT=3001
MCP_REDIS_HTTP_PORT=3002
MCP_AWS_HTTP_PORT=3003