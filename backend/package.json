{
  "name": "ai-devops-copilot",
  "version": "1.0.0",
  "description": "AI DevOps Copilot — a conversational infrastructure monitoring tool built with Node.js 24 + TypeScript backend, Angular 21 frontend, and Anthropic Claude API with MCP tool use. Engineers query PostgreSQL job data, Redis cache stats, and AWS Cost Explorer in plain English. Claude reasons across all three data sources using agentic tool calling to return a single intelligent answer. Portfolio project demonstrating production-grade agentic AI engineering, MCP protocol implementation, and modern full-stack development.",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev:server": "node --env-file=.env --import tsx/esm src/index.ts",
    "mcp:postgres": "node --env-file=.env --import tsx/esm src/mcp-servers/postgres-server.ts",
    "mcp:redis": "node --env-file=.env --import tsx/esm src/mcp-servers/redis-server.ts",
    "mcp:aws": "node --env-file=.env --import tsx/esm src/mcp-servers/aws-server.ts",
    "mcp:postgres:http": "node --env-file=.env --import tsx/esm src/mcp-servers/postgres-server.ts --transport=http",
    "mcp:redis:http": "node --env-file=.env --import tsx/esm src/mcp-servers/redis-server.ts --transport=http",
    "mcp:aws:http": "node --env-file=.env --import tsx/esm src/mcp-servers/aws-server.ts --transport=http",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "node --env-file=.env node_modules/.bin/vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@aws-sdk/client-cost-explorer": "^3.1029.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
